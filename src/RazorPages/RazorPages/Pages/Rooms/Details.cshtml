@page "{id:int}"
@model RazorPages.Pages.Rooms.DetailsModel
@{
    ViewData["Title"] = "Room " + Model.Room.RoomNumber;
}

<div class="mb-6">
    <a asp-page="Index" class="text-cascade-600 hover:text-cascade-800 text-sm">← Back to Rooms</a>
</div>

<div class="bg-white shadow rounded-lg p-6">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Room @Model.Room.RoomNumber</h1>
            @{
                var badgeColor = Model.Room.Type switch
                {
                    "Office" => "bg-blue-100 text-blue-800",
                    "Conference Room" => "bg-green-100 text-green-800",
                    "Break Room" => "bg-amber-100 text-amber-800",
                    _ => "bg-gray-100 text-gray-800"
                };
            }
            <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-medium @badgeColor mt-2">@Model.Room.Type</span>
        </div>
        <a asp-page="Edit" asp-route-id="@Model.Room.Id"
           class="inline-flex items-center rounded-md bg-cascade-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-cascade-500">
            ✏️ Edit Room
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-sm">
        <div>
            <span class="font-medium text-gray-500">Building:</span>
            <p class="text-gray-900">
                <a asp-page="/Buildings/Details" asp-route-id="@Model.Building.Id" class="text-cascade-600 hover:text-cascade-800">
                    @Model.Building.Name (@Model.Building.Code)
                </a>
            </p>
        </div>
        <div>
            <span class="font-medium text-gray-500">Floor:</span>
            <p class="text-gray-900">@Model.Room.Floor</p>
        </div>
        <div>
            <span class="font-medium text-gray-500">Capacity:</span>
            <p class="text-gray-900">@Model.Room.Capacity</p>
        </div>
        <div>
            <span class="font-medium text-gray-500">Window:</span>
            <p class="text-gray-900">@(Model.Room.HasWindow ? "✅ Yes" : "❌ No")</p>
        </div>
        @if (!string.IsNullOrEmpty(Model.Room.Notes))
        {
            <div class="md:col-span-2">
                <span class="font-medium text-gray-500">Notes:</span>
                <p class="text-gray-900">@Model.Room.Notes</p>
            </div>
        }
    </div>

    @if (Model.AssignedEmployee is not null)
    {
        <div class="mt-6 p-4 bg-cascade-50 rounded-lg">
            <h3 class="text-sm font-medium text-gray-500 mb-2">Assigned Employee</h3>
            <div class="flex items-center">
                <div>
                    <a asp-page="/Employees/Details" asp-route-id="@Model.AssignedEmployee.Id" class="text-lg font-semibold text-cascade-700 hover:text-cascade-800">
                        @Model.AssignedEmployee.FullName
                    </a>
                    <p class="text-sm text-gray-500">@Model.AssignedEmployee.Title — @Model.AssignedEmployee.Department</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="mt-6 p-4 bg-gray-50 rounded-lg">
            <p class="text-sm text-gray-500">This room is currently unoccupied.</p>
        </div>
    }
</div>
