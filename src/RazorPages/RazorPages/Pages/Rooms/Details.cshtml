@page "{id:int}"
@model RazorPages.Pages.Rooms.DetailsModel
@{
    ViewData["Title"] = "Room " + Model.Room.RoomNumber;
}

<div class="mb-6">
    <a asp-page="Index" class="text-cascade-600 hover:text-cascade-800 text-sm">← Back to Rooms</a>
</div>

<div class="bg-white shadow rounded-lg p-6">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Room @Model.Room.RoomNumber</h1>
            @{
                var badgeColor = Model.Room.Type switch {
                    "Office" => "bg-blue-100 text-blue-800",
                    "Conference Room" => "bg-green-100 text-green-800",
                    "Break Room" => "bg-amber-100 text-amber-800",
                    _ => "bg-gray-100 text-gray-800"
                };
            }
            <span class="inline-flex items-center rounded-full px-3 py-1 text-sm font-medium @badgeColor mt-2">@Model.Room.Type</span>
        </div>
        <a asp-page="Edit" asp-route-id="@Model.Room.Id" class="inline-flex items-center rounded-md bg-cascade-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-cascade-500">
            ✏️ Edit Room
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-sm">
        <div>
            <span class="font-medium text-gray-500">Building:</span>
            <a asp-page="/Buildings/Details" asp-route-id="@Model.Building.Id" class="text-cascade-600 hover:text-cascade-800 ml-1">@Model.Building.Name</a>
        </div>
        <div><span class="font-medium text-gray-500">Floor:</span> <span class="text-gray-900">@Model.Room.Floor</span></div>
        <div><span class="font-medium text-gray-500">Capacity:</span> <span class="text-gray-900">@Model.Room.Capacity</span></div>
        <div><span class="font-medium text-gray-500">Window:</span> <span class="text-gray-900">@(Model.Room.HasWindow ? "✅ Yes" : "❌ No")</span></div>
        @if (!string.IsNullOrEmpty(Model.Room.Notes))
        {
            <div class="md:col-span-2"><span class="font-medium text-gray-500">Notes:</span> <span class="text-gray-900">@Model.Room.Notes</span></div>
        }
    </div>

    @if (Model.AssignedEmployee is not null)
    {
        <div class="mt-6 border-t pt-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-3">👤 Assigned Employee</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                <div>
                    <span class="font-medium text-gray-500">Name:</span>
                    <a asp-page="/Employees/Details" asp-route-id="@Model.AssignedEmployee.Id" class="text-cascade-600 hover:text-cascade-800 ml-1">@Model.AssignedEmployee.FullName</a>
                </div>
                <div><span class="font-medium text-gray-500">Department:</span> <span class="text-gray-900">@Model.AssignedEmployee.Department</span></div>
                <div><span class="font-medium text-gray-500">Title:</span> <span class="text-gray-900">@Model.AssignedEmployee.Title</span></div>
                <div><span class="font-medium text-gray-500">Email:</span> <span class="text-gray-900">@Model.AssignedEmployee.Email</span></div>
            </div>
        </div>
    }
    else
    {
        <div class="mt-6 border-t pt-6">
            <p class="text-gray-500 text-sm">This room is currently unoccupied.</p>
        </div>
    }
</div>
