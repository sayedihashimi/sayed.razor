@page
@model RazorPages.Pages.Rooms.IndexModel
@{
    ViewData["Title"] = "Rooms";
}

<div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900">🚪 Rooms</h1>
    <p class="mt-2 text-gray-600">Showing @Model.Rooms.Count rooms</p>
</div>

<!-- Filters -->
<div class="bg-white shadow rounded-lg p-4 mb-6">
    <form method="get" class="grid grid-cols-1 sm:grid-cols-4 gap-4">
        <div>
            <label for="buildingId" class="block text-sm font-medium text-gray-700 mb-1">Building</label>
            <select name="BuildingId" id="buildingId" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-cascade-500 focus:ring-cascade-500 text-sm px-3 py-2 border">
                <option value="">All Buildings</option>
                @foreach (var b in Model.Buildings)
                {
                    <option value="@b.Id" selected="@(Model.BuildingId == b.Id)">@b.Name</option>
                }
            </select>
        </div>
        <div>
            <label for="floor" class="block text-sm font-medium text-gray-700 mb-1">Floor</label>
            <select name="Floor" id="floor" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-cascade-500 focus:ring-cascade-500 text-sm px-3 py-2 border">
                <option value="">All Floors</option>
                @for (int i = 1; i <= 4; i++)
                {
                    <option value="@i" selected="@(Model.Floor == i)">Floor @i</option>
                }
            </select>
        </div>
        <div>
            <label for="roomType" class="block text-sm font-medium text-gray-700 mb-1">Room Type</label>
            <select name="RoomType" id="roomType" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-cascade-500 focus:ring-cascade-500 text-sm px-3 py-2 border">
                <option value="">All Types</option>
                <option value="Office" selected="@(Model.RoomType == "Office")">Office</option>
                <option value="Conference Room" selected="@(Model.RoomType == "Conference Room")">Conference Room</option>
                <option value="Break Room" selected="@(Model.RoomType == "Break Room")">Break Room</option>
                <option value="Server Room" selected="@(Model.RoomType == "Server Room")">Server Room</option>
                <option value="UX Lab" selected="@(Model.RoomType == "UX Lab")">UX Lab</option>
                <option value="Demo Center" selected="@(Model.RoomType == "Demo Center")">Demo Center</option>
                <option value="Records Room" selected="@(Model.RoomType == "Records Room")">Records Room</option>
                <option value="Prototyping Lab" selected="@(Model.RoomType == "Prototyping Lab")">Prototyping Lab</option>
                <option value="Executive Boardroom" selected="@(Model.RoomType == "Executive Boardroom")">Executive Boardroom</option>
                <option value="Wellness Center" selected="@(Model.RoomType == "Wellness Center")">Wellness Center</option>
            </select>
        </div>
        <div class="flex items-end">
            <button type="submit" class="inline-flex items-center rounded-md bg-cascade-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-cascade-500 w-full justify-center">
                🔍 Filter
            </button>
        </div>
    </form>
</div>

<!-- Results Table -->
<div class="bg-white shadow rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Room Number</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Building</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Floor</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Capacity</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Window</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Assigned Employee</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
            @foreach (var room in Model.Rooms)
            {
                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-3 whitespace-nowrap text-sm font-medium text-gray-900">@room.RoomNumber</td>
                    <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500">@Model.GetBuildingName(room.BuildingId)</td>
                    <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500">@room.Floor</td>
                    <td class="px-6 py-3 whitespace-nowrap text-sm">
                        @{
                            var badgeColor = room.Type switch
                            {
                                "Office" => "bg-blue-100 text-blue-800",
                                "Conference Room" => "bg-green-100 text-green-800",
                                "Break Room" => "bg-amber-100 text-amber-800",
                                _ => "bg-gray-100 text-gray-800"
                            };
                        }
                        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium @badgeColor">@room.Type</span>
                    </td>
                    <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500">@room.Capacity</td>
                    <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500">@(room.HasWindow ? "✅" : "—")</td>
                    <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500">
                        @if (room.AssignedEmployeeId.HasValue)
                        {
                            <a asp-page="/Employees/Details" asp-route-id="@room.AssignedEmployeeId" class="text-cascade-600 hover:text-cascade-800">
                                @Model.GetEmployeeName(room.AssignedEmployeeId)
                            </a>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </td>
                    <td class="px-6 py-3 whitespace-nowrap text-right text-sm font-medium">
                        <a asp-page="Details" asp-route-id="@room.Id" class="text-cascade-600 hover:text-cascade-900">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
