@page "{id:int}"
@model RazorPages.Pages.Buildings.DetailsModel
@{
    ViewData["Title"] = Model.Building.Name;
}

<div class="mb-6">
    <a asp-page="Index" class="text-cascade-600 hover:text-cascade-800 text-sm">← Back to Buildings</a>
</div>

<!-- Building Info Card -->
<div class="bg-white shadow rounded-lg p-6 mb-8">
    <div class="flex items-center justify-between mb-4">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">@Model.Building.Name</h1>
            <span class="inline-flex items-center rounded-full bg-cascade-100 px-3 py-1 text-sm font-medium text-cascade-800 mt-2">Building @Model.Building.Code</span>
        </div>
        <a asp-page="Edit" asp-route-id="@Model.Building.Id" class="inline-flex items-center rounded-md bg-cascade-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-cascade-500">
            ✏️ Edit Building
        </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
        <div><span class="font-medium text-gray-500">Address:</span> <span class="text-gray-900">@Model.Building.Address, @Model.Building.City, @Model.Building.State @Model.Building.ZipCode</span></div>
        <div><span class="font-medium text-gray-500">Phone:</span> <span class="text-gray-900">@Model.Building.Phone</span></div>
        <div><span class="font-medium text-gray-500">Floors:</span> <span class="text-gray-900">@Model.Building.Floors</span></div>
        <div><span class="font-medium text-gray-500">Year Built:</span> <span class="text-gray-900">@Model.Building.YearBuilt</span></div>
        <div class="md:col-span-2"><span class="font-medium text-gray-500">Primary Departments:</span> <span class="text-gray-900">@Model.Building.PrimaryDepartments</span></div>
        <div class="md:col-span-2"><span class="font-medium text-gray-500">Description:</span> <span class="text-gray-900">@Model.Building.Description</span></div>
    </div>
</div>

<!-- Rooms by Floor -->
<h2 class="text-xl font-semibold text-gray-900 mb-4">🚪 Rooms (@Model.Rooms.Count total)</h2>
@foreach (var floor in Model.RoomsByFloor)
{
    <div class="mb-6">
        <h3 class="text-lg font-medium text-gray-700 mb-2">Floor @floor.Key</h3>
        <div class="overflow-hidden bg-white shadow ring-1 ring-black/5 sm:rounded-lg">
            <table class="min-w-full divide-y divide-gray-300">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Room</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Capacity</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Window</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Assigned Employee</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var room in floor.Value)
                    {
                        <tr class="hover:bg-gray-50">
                            <td class="px-4 py-2 text-sm font-medium text-gray-900">@room.RoomNumber</td>
                            <td class="px-4 py-2 text-sm">
                                @{
                                    var badgeColor = room.Type switch {
                                        "Office" => "bg-blue-100 text-blue-800",
                                        "Conference Room" => "bg-green-100 text-green-800",
                                        "Break Room" => "bg-amber-100 text-amber-800",
                                        _ => "bg-gray-100 text-gray-800"
                                    };
                                }
                                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium @badgeColor">@room.Type</span>
                            </td>
                            <td class="px-4 py-2 text-sm text-gray-500">@room.Capacity</td>
                            <td class="px-4 py-2 text-sm text-gray-500">@(room.HasWindow ? "✅" : "—")</td>
                            <td class="px-4 py-2 text-sm text-gray-500">
                                @if (room.AssignedEmployeeId.HasValue)
                                {
                                    <a asp-page="/Employees/Details" asp-route-id="@room.AssignedEmployeeId.Value" class="text-cascade-600 hover:text-cascade-800">@Model.GetEmployeeName(room.AssignedEmployeeId)</a>
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Employees in Building -->
<h2 class="text-xl font-semibold text-gray-900 mb-4 mt-8">👥 Employees (@Model.Employees.Count)</h2>
<div class="overflow-hidden bg-white shadow ring-1 ring-black/5 sm:rounded-lg">
    <table class="min-w-full divide-y divide-gray-300">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Department</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Title</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Room</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
            @foreach (var emp in Model.Employees.OrderBy(e => e.LastName))
            {
                <tr class="hover:bg-gray-50">
                    <td class="px-4 py-2 text-sm">
                        <a asp-page="/Employees/Details" asp-route-id="@emp.Id" class="text-cascade-600 hover:text-cascade-800 font-medium">@emp.FullName</a>
                    </td>
                    <td class="px-4 py-2 text-sm text-gray-500">@emp.Department</td>
                    <td class="px-4 py-2 text-sm text-gray-500">@emp.Title</td>
                    <td class="px-4 py-2 text-sm text-gray-500">@emp.RoomId</td>
                </tr>
            }
        </tbody>
    </table>
</div>
