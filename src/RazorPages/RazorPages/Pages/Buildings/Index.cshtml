@page
@model RazorPages.Pages.Buildings.IndexModel
@{
    ViewData["Title"] = "Buildings";
}

<div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900">🏗️ Office Buildings</h1>
    <p class="mt-2 text-gray-600">All @Model.Buildings.Count campus buildings</p>
</div>

<div class="overflow-hidden bg-white shadow ring-1 ring-black/5 sm:rounded-lg">
    <table class="min-w-full divide-y divide-gray-300">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-4 py-3.5 text-left text-sm font-semibold text-gray-900">Code</th>
                <th class="px-4 py-3.5 text-left text-sm font-semibold text-gray-900">Name</th>
                <th class="px-4 py-3.5 text-left text-sm font-semibold text-gray-900">Address</th>
                <th class="px-4 py-3.5 text-left text-sm font-semibold text-gray-900">Floors</th>
                <th class="px-4 py-3.5 text-left text-sm font-semibold text-gray-900">Year Built</th>
                <th class="px-4 py-3.5 text-left text-sm font-semibold text-gray-900">Employees</th>
                <th class="px-4 py-3.5 text-left text-sm font-semibold text-gray-900">Rooms</th>
                <th class="px-4 py-3.5 text-left text-sm font-semibold text-gray-900"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
            @foreach (var b in Model.Buildings)
            {
                <tr class="hover:bg-gray-50">
                    <td class="whitespace-nowrap px-4 py-4">
                        <span class="inline-flex items-center rounded-full bg-cascade-100 px-2.5 py-0.5 text-xs font-medium text-cascade-800">@b.Code</span>
                    </td>
                    <td class="whitespace-nowrap px-4 py-4 text-sm font-medium text-gray-900">@b.Name</td>
                    <td class="whitespace-nowrap px-4 py-4 text-sm text-gray-500">@b.Address, @b.City, @b.State</td>
                    <td class="whitespace-nowrap px-4 py-4 text-sm text-gray-500">@b.Floors</td>
                    <td class="whitespace-nowrap px-4 py-4 text-sm text-gray-500">@b.YearBuilt</td>
                    <td class="whitespace-nowrap px-4 py-4 text-sm text-gray-500">@Model.EmployeeCounts[b.Id]</td>
                    <td class="whitespace-nowrap px-4 py-4 text-sm text-gray-500">@Model.RoomCounts[b.Id]</td>
                    <td class="whitespace-nowrap px-4 py-4 text-sm">
                        <a asp-page="Details" asp-route-id="@b.Id" class="text-cascade-600 hover:text-cascade-900 font-medium">View Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
