@page "{id:int}"
@model RazorPages.Pages.Buildings.EditModel
@{
    ViewData["Title"] = "Edit " + Model.Building.Name;
}

<div class="mb-6">
    <a asp-page="Details" asp-route-id="@Model.Building.Id" class="text-cascade-600 hover:text-cascade-800 text-sm">← Back to @Model.Building.Name</a>
</div>

<div class="bg-white shadow rounded-lg p-6">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">✏️ Edit @Model.Building.Name</h1>

    <!-- Read-only info -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6 p-4 bg-gray-50 rounded-lg">
        <div>
            <span class="text-xs font-medium text-gray-500 uppercase">Building Code</span>
            <p class="text-sm font-semibold text-gray-900">@Model.Building.Code</p>
        </div>
        <div>
            <span class="text-xs font-medium text-gray-500 uppercase">Floors</span>
            <p class="text-sm font-semibold text-gray-900">@Model.Building.Floors</p>
        </div>
        <div>
            <span class="text-xs font-medium text-gray-500 uppercase">Year Built</span>
            <p class="text-sm font-semibold text-gray-900">@Model.Building.YearBuilt</p>
        </div>
        <div>
            <span class="text-xs font-medium text-gray-500 uppercase">ID</span>
            <p class="text-sm font-semibold text-gray-900">@Model.Building.Id</p>
        </div>
    </div>

    <form method="post" data-confirm="Are you sure you want to update this building's information?">
        <input type="hidden" asp-for="Building.Id" />
        <input type="hidden" asp-for="Building.Code" />
        <input type="hidden" asp-for="Building.Floors" />
        <input type="hidden" asp-for="Building.YearBuilt" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label asp-for="Building.Name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                <input asp-for="Building.Name" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-cascade-500 focus:ring-cascade-500 text-sm px-3 py-2 border" />
            </div>
            <div>
                <label asp-for="Building.Phone" class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
                <input asp-for="Building.Phone" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-cascade-500 focus:ring-cascade-500 text-sm px-3 py-2 border" />
            </div>
            <div>
                <label asp-for="Building.Address" class="block text-sm font-medium text-gray-700 mb-1">Address</label>
                <input asp-for="Building.Address" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-cascade-500 focus:ring-cascade-500 text-sm px-3 py-2 border" />
            </div>
            <div>
                <label asp-for="Building.City" class="block text-sm font-medium text-gray-700 mb-1">City</label>
                <input asp-for="Building.City" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-cascade-500 focus:ring-cascade-500 text-sm px-3 py-2 border" />
            </div>
            <div>
                <label asp-for="Building.State" class="block text-sm font-medium text-gray-700 mb-1">State</label>
                <input asp-for="Building.State" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-cascade-500 focus:ring-cascade-500 text-sm px-3 py-2 border" />
            </div>
            <div>
                <label asp-for="Building.ZipCode" class="block text-sm font-medium text-gray-700 mb-1">Zip Code</label>
                <input asp-for="Building.ZipCode" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-cascade-500 focus:ring-cascade-500 text-sm px-3 py-2 border" />
            </div>
            <div class="md:col-span-2">
                <label asp-for="Building.PrimaryDepartments" class="block text-sm font-medium text-gray-700 mb-1">Primary Departments</label>
                <input asp-for="Building.PrimaryDepartments" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-cascade-500 focus:ring-cascade-500 text-sm px-3 py-2 border" />
            </div>
            <div class="md:col-span-2">
                <label asp-for="Building.Description" class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                <textarea asp-for="Building.Description" rows="3" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-cascade-500 focus:ring-cascade-500 text-sm px-3 py-2 border"></textarea>
            </div>
        </div>

        <div class="mt-6 flex items-center gap-4">
            <button type="submit" class="inline-flex items-center rounded-md bg-cascade-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-cascade-500">
                💾 Save Changes
            </button>
            <a asp-page="Details" asp-route-id="@Model.Building.Id" class="text-sm text-gray-600 hover:text-gray-900">Cancel</a>
        </div>
    </form>
</div>
