@page "{id:int}"
@model RazorPages.Pages.Employees.DetailsModel
@{
    ViewData["Title"] = Model.Employee.FullName;
}

<div class="mb-6">
    <a asp-page="Index" class="text-cascade-600 hover:text-cascade-800 text-sm">← Back to Employees</a>
</div>

<div class="bg-white shadow rounded-lg p-6">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">@Model.Employee.FullName</h1>
            <p class="text-lg text-gray-600 mt-1">@Model.Employee.Title</p>
            <span class="inline-flex items-center rounded-full bg-purple-100 px-3 py-1 text-sm font-medium text-purple-800 mt-2">@Model.Employee.Department</span>
        </div>
        <a asp-page="Edit" asp-route-id="@Model.Employee.Id" class="inline-flex items-center rounded-md bg-cascade-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-cascade-500">
            ✏️ Edit Employee
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Left Column -->
        <div class="space-y-4 text-sm">
            <h2 class="text-lg font-semibold text-gray-900 border-b pb-2">Contact Information</h2>
            <div><span class="font-medium text-gray-500">Email:</span> <a href="mailto:@Model.Employee.Email" class="text-cascade-600 hover:text-cascade-800 ml-1">@Model.Employee.Email</a></div>
            <div><span class="font-medium text-gray-500">Phone:</span> <span class="text-gray-900">@Model.Employee.Phone</span></div>
            <div><span class="font-medium text-gray-500">Hire Date:</span> <span class="text-gray-900">@Model.Employee.HireDate.ToString("MMMM d, yyyy")</span></div>
        </div>

        <!-- Right Column -->
        <div class="space-y-4 text-sm">
            <h2 class="text-lg font-semibold text-gray-900 border-b pb-2">Location & Emergency</h2>
            <div>
                <span class="font-medium text-gray-500">Building:</span>
                <a asp-page="/Buildings/Details" asp-route-id="@Model.Building.Id" class="text-cascade-600 hover:text-cascade-800 ml-1">@Model.Building.Name</a>
            </div>
            <div>
                <span class="font-medium text-gray-500">Room:</span>
                <a asp-page="/Rooms/Details" asp-route-id="@Model.Room.Id" class="text-cascade-600 hover:text-cascade-800 ml-1">@Model.Room.RoomNumber</a>
            </div>
            <div><span class="font-medium text-gray-500">Emergency Contact:</span> <span class="text-gray-900">@Model.Employee.EmergencyContactName</span></div>
            <div><span class="font-medium text-gray-500">Emergency Phone:</span> <span class="text-gray-900">@Model.Employee.EmergencyContactPhone</span></div>
        </div>
    </div>
</div>
