@page "{id:int}"
@model RazorPages.Pages.Employees.DetailsModel
@{
    ViewData["Title"] = Model.Employee.FullName;
}

<div class="mb-6">
    <a asp-page="Index" class="text-cascade-600 hover:text-cascade-800 text-sm">← Back to Employees</a>
</div>

<div class="bg-white shadow rounded-lg p-6">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl font-bold text-gray-900">@Model.Employee.FullName</h1>
        <a asp-page="Edit" asp-route-id="@Model.Employee.Id"
           class="inline-flex items-center rounded-md bg-cascade-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-cascade-500">
            ✏️ Edit Employee
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Left Column -->
        <div class="space-y-4">
            <div>
                <span class="text-sm font-medium text-gray-500">Title</span>
                <p class="text-lg text-gray-900">@Model.Employee.Title</p>
            </div>
            <div>
                <span class="text-sm font-medium text-gray-500">Department</span>
                <p>
                    <span class="inline-flex items-center rounded-full bg-indigo-100 px-3 py-1 text-sm font-medium text-indigo-800">
                        @Model.Employee.Department
                    </span>
                </p>
            </div>
            <div>
                <span class="text-sm font-medium text-gray-500">Email</span>
                <p class="text-gray-900">
                    <a href="mailto:@Model.Employee.Email" class="text-cascade-600 hover:text-cascade-800">@Model.Employee.Email</a>
                </p>
            </div>
            <div>
                <span class="text-sm font-medium text-gray-500">Phone</span>
                <p class="text-gray-900">@Model.Employee.Phone</p>
            </div>
            <div>
                <span class="text-sm font-medium text-gray-500">Hire Date</span>
                <p class="text-gray-900">@Model.Employee.HireDate.ToString("MMMM d, yyyy")</p>
            </div>
        </div>

        <!-- Right Column -->
        <div class="space-y-4">
            <div>
                <span class="text-sm font-medium text-gray-500">Building</span>
                <p class="text-gray-900">
                    <a asp-page="/Buildings/Details" asp-route-id="@Model.Building.Id" class="text-cascade-600 hover:text-cascade-800">
                        @Model.Building.Name (@Model.Building.Code)
                    </a>
                </p>
            </div>
            <div>
                <span class="text-sm font-medium text-gray-500">Room</span>
                <p class="text-gray-900">
                    <a asp-page="/Rooms/Details" asp-route-id="@Model.Room.Id" class="text-cascade-600 hover:text-cascade-800">
                        @Model.Room.RoomNumber
                    </a>
                </p>
            </div>
            <div class="mt-6 p-4 bg-amber-50 rounded-lg border border-amber-200">
                <h3 class="text-sm font-semibold text-amber-800 mb-2">🆘 Emergency Contact</h3>
                <div class="space-y-1">
                    <p class="text-sm text-gray-900"><span class="font-medium">Name:</span> @Model.Employee.EmergencyContactName</p>
                    <p class="text-sm text-gray-900"><span class="font-medium">Phone:</span> @Model.Employee.EmergencyContactPhone</p>
                </div>
            </div>
        </div>
    </div>
</div>
