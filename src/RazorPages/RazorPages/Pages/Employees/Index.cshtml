@page
@model RazorPages.Pages.Employees.IndexModel
@{
    ViewData["Title"] = "Employees";
}

<div class="mb-6">
    <div class="flex items-center gap-3">
        <h1 class="text-3xl font-bold text-gray-900">👥 Employees</h1>
        <span class="inline-flex items-center rounded-full bg-cascade-100 px-3 py-1 text-sm font-medium text-cascade-800">
            @Model.Employees.Count employees
        </span>
    </div>
</div>

<!-- Filters -->
<div class="bg-white shadow rounded-lg p-4 mb-6">
    <form method="get" class="grid grid-cols-1 sm:grid-cols-4 gap-4">
        <div>
            <label for="search" class="block text-sm font-medium text-gray-700 mb-1">Search</label>
            <input type="text" name="Search" id="search" value="@Model.Search" placeholder="Name or email..."
                   class="block w-full rounded-md border-gray-300 shadow-sm focus:border-cascade-500 focus:ring-cascade-500 text-sm px-3 py-2 border" />
        </div>
        <div>
            <label for="department" class="block text-sm font-medium text-gray-700 mb-1">Department</label>
            <select name="Department" id="department" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-cascade-500 focus:ring-cascade-500 text-sm px-3 py-2 border">
                <option value="">All Departments</option>
                @foreach (var dept in Model.Departments)
                {
                    <option value="@dept" selected="@(Model.Department == dept)">@dept</option>
                }
            </select>
        </div>
        <div>
            <label for="buildingId" class="block text-sm font-medium text-gray-700 mb-1">Building</label>
            <select name="BuildingId" id="buildingId" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-cascade-500 focus:ring-cascade-500 text-sm px-3 py-2 border">
                <option value="">All Buildings</option>
                @foreach (var b in Model.Buildings)
                {
                    <option value="@b.Id" selected="@(Model.BuildingId == b.Id)">@b.Name</option>
                }
            </select>
        </div>
        <div class="flex items-end">
            <button type="submit" class="inline-flex items-center rounded-md bg-cascade-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-cascade-500 w-full justify-center">
                🔍 Filter
            </button>
        </div>
    </form>
</div>

<!-- Results Table -->
<div class="bg-white shadow rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Department</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Title</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Building</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Room</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
            @{ var rowIdx = 0; }
            @foreach (var emp in Model.Employees)
            {
                <tr class="@(rowIdx % 2 == 0 ? "bg-white" : "bg-gray-50") hover:bg-cascade-50">
                    <td class="px-6 py-3 whitespace-nowrap text-sm font-medium">
                        <a asp-page="Details" asp-route-id="@emp.Id" class="text-cascade-600 hover:text-cascade-800">@emp.FullName</a>
                    </td>
                    <td class="px-6 py-3 whitespace-nowrap text-sm">
                        <span class="inline-flex items-center rounded-full bg-indigo-100 px-2.5 py-0.5 text-xs font-medium text-indigo-800">@emp.Department</span>
                    </td>
                    <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500">@emp.Title</td>
                    <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500">@Model.GetBuildingName(emp.BuildingId)</td>
                    <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500">@Model.GetRoomNumber(emp.RoomId)</td>
                    <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500">
                        <a href="mailto:@emp.Email" class="text-cascade-600 hover:text-cascade-800">@emp.Email</a>
                    </td>
                </tr>
                rowIdx++;
            }
        </tbody>
    </table>
</div>
